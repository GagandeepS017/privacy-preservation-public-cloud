# ---------------------------------------------------------------------------
# Backend configuration. Copy this file to `.env` and adjust as needed.
# ---------------------------------------------------------------------------

# Secret used to sign JWT access tokens. Change this to a long random string.
JWT_SECRET_KEY=super-secret-change-me

# How long (in minutes) an issued access token stays valid.
JWT_ACCESS_TOKEN_MINUTES=60

# Host / port the API listens on.
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=3001

# Comma separated list of origins allowed to call the API (the React app).
# Use * to allow any origin during local development.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Seed demo account created on first run so the app is usable immediately.
# These reproduce the credentials used in the original project report.
SEED_DEMO_USER=true
DEMO_EMAIL=test
DEMO_PASSWORD=test

# ---------------------------------------------------------------------------
# Optional: Exadel CompreFace face-verification service.
# Leave COMPREFACE_URL empty to disable the biometric layer entirely - the
# rest of the application works without it.
# ---------------------------------------------------------------------------
COMPREFACE_URL=
COMPREFACE_API_KEY=
# Minimum similarity (0-1) required to accept a face match.
FACE_SIMILARITY_THRESHOLD=0.95
